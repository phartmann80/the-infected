{
  "name": "the-infected",
  "version": "0.1.0",
  "private": true,
  "description": "Foundation v2 game-first monorepo for The Infected.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspace @the-infected/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate:registry": "node scripts/validate-registry.mjs",
    "ci": "npm run validate:registry && npm run secrets:scan && npm run lint && npm run typecheck && npm run build",
    "secrets:scan": "node scripts/scan-secrets.mjs",
    "test:image-generation": "vitest run scripts/image-generation/tests",
    "image:generate:self-check": "tsx scripts/image-generation/generate.ts --provider mock --brief hero-key-art-001 --reference assets/visual_benchmarks/Visual_Benchmark_Candidate_001.png --output .tmp/image-generation-self-check --dry-run",
    "image:generate": "tsx scripts/image-generation/generate.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "packageManager": "npm@11.17.0",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
